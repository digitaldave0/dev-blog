---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import SideBar from "../components/SideBar.astro";
import { ViewTransitions } from "astro:transitions";
import "@fontsource/inter";

import { SITE_TITLE, SITE_DESCRIPTION, TRANSITION_API } from "../config";

const {
  image,
  title = SITE_TITLE,
  description = SITE_DESCRIPTION,
  includeSidebar = true,
  sideBarActiveItemID,
  ogType,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={title} description={description} image={image} , ogType={ogType} />
    {TRANSITION_API && <ViewTransitions />}
    <script is:inline>
      // Initialize theme from local storage or default to 'lofi'
      const theme = localStorage.getItem('theme') || 'lofi';
      document.documentElement.setAttribute('data-theme', theme);
    </script>
    <script is:inline src="https://cdn.jsdelivr.net/npm/mermaid@10/dist/mermaid.min.js"></script>
    <script is:inline>
      const initializeMermaid = () => {
        if (typeof mermaid === 'undefined') return;
        
        const isDark = localStorage.getItem('theme') === 'black';
        mermaid.initialize({
          startOnLoad: false,
          theme: isDark ? 'dark' : 'default',
          securityLevel: 'loose',
        });
        
        // Find all code blocks that should be mermaid diagrams
        // Standard markdown: pre code.language-mermaid
        // Astro/Shiki might have varied structures
        const blocks = document.querySelectorAll('pre code.language-mermaid, pre.mermaid, div.mermaid');
        
        console.log(`[Mermaid] Found ${blocks.length} potential diagrams`);

        blocks.forEach((block, index) => {
          const container = block.tagName === 'CODE' ? block.parentElement : block;
          const rawContent = block.innerText || block.textContent;
          
          const id = `mermaid-svg-${index}`;
          const div = document.createElement('div');
          div.className = 'mermaid-container flex justify-center my-8 p-4 bg-white/5 rounded-lg';
          div.id = `container-${id}`;
          
          // Set the raw content for mermaid to process
          div.innerHTML = rawContent.trim();
          
          // Replace the original block
          container.replaceWith(div);
        });
        
        mermaid.run({
          querySelector: '.mermaid-container',
        });
      };

      document.addEventListener('DOMContentLoaded', initializeMermaid);
      document.addEventListener('astro:after-swap', initializeMermaid);
    </script>
  </head>
  <body>
    <div class="bg-base-100 drawer lg:drawer-open">
      <input id="my-drawer" type="checkbox" class="drawer-toggle" />
      <div class="drawer-content bg-base-100">
        <Header title={SITE_TITLE} />
        <div class="md:flex md:justify-center">
          <main class="p-6 pt-10 lg:max-w-[900px] max-w-[100vw]">
            <slot />
          </main>
        </div>
        <Footer />
      </div>
      {includeSidebar && <SideBar sideBarActiveItemID={sideBarActiveItemID} />}
    </div>
  </body>
</html>
